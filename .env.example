# ============================================================
# .env  — copy this to .env and fill in your credentials
# ============================================================

# ── Zerodha Kite Connect ─────────────────────────────────────
KITE_API_KEY=your_kite_api_key_here
KITE_ACCESS_TOKEN=your_kite_access_token_here

# ── Trading Mode ─────────────────────────────────────────────
# Set to "paper" to run without real orders, "live" for real trades
TRADE_MODE=paper

# ── Capital ──────────────────────────────────────────────────
CAPITAL=100000

# ── MLflow ───────────────────────────────────────────────────
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_EXPERIMENT=RL_MLOPS_TRADING

# ── Prometheus ───────────────────────────────────────────────
PROMETHEUS_PORT=8000

# ── Dashboard ────────────────────────────────────────────────
DASHBOARD_PORT=8050

# ── Sleep between trading cycles (seconds) ───────────────────
SLEEP_SECONDS=300
